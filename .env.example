# OpenCode Go Multi-Account Router Configuration
# Copy to .env and adjust as needed

# Upstream OpenCode Go API base URL
UPSTREAM_URL=https://opencode.ai/zen/go/v1

# Dashboard UI port
DASHBOARD_PORT=18904

# Proxy server port
PROXY_PORT=18905

# Default quota limit per key (in USD)
QUOTA_LIMIT=60

# Cooldown duration for exhausted keys (in ms, default 5 hours)
COOLDOWN_MS=18000000

# Circuit breaker: consecutive 5xx errors before tripping
CIRCUIT_BREAKER_THRESHOLD=3

# Proactive switch: usage fraction (0-1) that triggers preemptive spillover
PROACTIVE_SWITCH_THRESHOLD=0.95

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Path to config directory (default: ~/.opencode)
CONFIG_DIR=

# ntfy notification URL (optional — leave empty to disable notifications)
# Example: https://ntfy.sh/mytopic
NTFY_URL=
