# OpenCode Go Multi-Account Router Configuration
# Copy to .env and adjust as needed
#
# The router does NOT estimate quota. It reacts to upstream 402/429
# responses and fails over to the next key for the duration that the
# upstream itself specifies (Retry-After / x-codex-*-reset-at /
# "try again in N m" body fields). When the upstream gives no signal,
# COOLDOWN_MS is used as the fallback.

# Upstream OpenCode Go API base URL
UPSTREAM_URL=https://opencode.ai/zen/go/v1

# Dashboard UI port
DASHBOARD_PORT=18904

# Proxy server port
PROXY_PORT=18905

# Fallback cooldown in ms, used only when the upstream returns 402/429
# without a Retry-After header, body, or x-codex reset header.
# Default: 5 hours.
COOLDOWN_MS=18000000

# Circuit breaker: consecutive 5xx errors before tripping
CIRCUIT_BREAKER_THRESHOLD=3

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Path to config directory (default: ~/.opencode)
CONFIG_DIR=

# ntfy notification URL (optional — leave empty to disable notifications)
# Example: https://ntfy.sh/mytopic
NTFY_URL=

# Upstream request timeout in milliseconds (0 = disabled, mirrors OpenCode's
# no-timeout default for the opencode-go provider). Set to a positive value to
# enforce a wall-clock cap on the upstream HTTP round-trip.
REQUEST_TIMEOUT_MS=0

# Hung-connection guard in milliseconds (0 = disabled). Aborts the upstream
# fetch if no response is received at all within this window. Set this if you
# want a safety net against a stuck socket pinning a worker. Unlike
# REQUEST_TIMEOUT_MS, this guard is cleared as soon as the upstream starts
# sending bytes.
UPSTREAM_HUNG_TIMEOUT_MS=0

# HTTP keep-alive timeout on the proxy server in milliseconds. Default 300000
# (5 min). Node's built-in default is 5s, which is too aggressive when
# OpenCode (or any other client) reuses a persistent connection — the
# connection gets closed under it and the next request fails with
# "socket connection was closed unexpectedly". Bump this if you see that
# error from an OpenCode session.
KEEP_ALIVE_TIMEOUT_MS=300000

# Time the server waits for the full request headers (and any body, when
# the proxy enforces REQUEST_TIMEOUT_MS) to arrive. Default 60000 (60s).
# Must be > KEEP_ALIVE_TIMEOUT_MS or Node will warn and clamp.
HEADERS_TIMEOUT_MS=60000
